# Environment
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.egg-info/
dist/
build/

# Alembic generated versions (commit manually)
alembic/versions/*.py
!alembic/versions/.gitkeep

# Security reports (generated by CI)
security/reports/*.json
security/reports/*.html
!security/reports/.gitkeep

# Storage (encrypted file chunks — never commit)
storage/
!storage/.gitkeep

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
*.Zone.Identifier

# Working materials (not part of the project)
new_docs/
